# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (mode test pour commencer)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
# Phase 6: 17€ one-time price for the post-checkout upsell
STRIPE_UPSELL_PRICE_ID=price_...
# Récupéré depuis `stripe listen` en local, ou Dashboard Stripe en prod
STRIPE_WEBHOOK_SECRET=whsec_...

# URL publique (utilisée pour success_url / cancel_url Stripe)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin back-office
# Single-password gate for /admin/*. Pick a long random string.
ADMIN_PASSWORD=change-me
# Used to HMAC-sign the admin_session cookie. Generate with:
#   openssl rand -base64 32
ADMIN_SESSION_SECRET=change-me

# Resend (Phase 3+)
# Get a key at https://resend.com — leave empty until ready; email sends will
# log as `skipped_no_provider` and the rest of the app keeps working.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_REPLY_TO=contact@osmo-lab.fr

# Cron auth (Phase 5)
# Vercel injects `Authorization: Bearer <CRON_SECRET>` on cron requests.
CRON_SECRET=change-me
